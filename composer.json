{
  "name": "marketbw/site",
  "version": "3.10.1",
  "description": "Bead Wonder — визитка рукоделия (Slim 4, Twig 3, SQLite)",
  "type": "project",
  "require": {
    "php": "^8.2",
    "slim/slim": "^4.13",
    "slim/psr7": "^1.7",
    "slim/twig-view": "^3.4",
    "twig/twig": "^3.14",
    "php-di/php-di": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
