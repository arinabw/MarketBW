{% extends "base.twig" %}

{% block title %}{{ t('contact.page_title') }} — заказ украшений из бисера | {{ site_name }}{% endblock %}
{% block meta_description %}{{ t('contact.page_sub') }} Заказ бижутерии, украшений из бисера и оригинальных подарков ручной работы.{% endblock %}

{% block head_structured_extra %}
{% if breadcrumb_json_ld is defined and breadcrumb_json_ld != '' %}
<script type="application/ld+json">{{ breadcrumb_json_ld|raw }}</script>
{% endif %}
{% endblock %}

{% block body %}
<section class="page-hero">
  <div class="container">
    <h1>{{ t('contact.page_title') }}</h1>
    <p class="muted">{{ t('contact.page_sub') }}</p>
  </div>
</section>

<section class="section section--white">
  <div class="container contact-grid">
    <div class="box contact-card">
      <h2 class="box__title">{{ t('contact.box_contacts_title') }}</h2>
      <p><strong>{{ t('contact.label_email') }}</strong> <a href="mailto:{{ contact_email }}?subject={{ 'Заказ с сайта '|url_encode }}{{ site_name|url_encode }}">{{ contact_email }}</a></p>
    </div>
    <div class="box contact-card">
      <h2 class="box__title">{{ t('contact.box_message_title') }}</h2>
      {% if sent %}
      <p class="alert alert--success">{{ t('contact.form_success') }}</p>
      {% endif %}
      {% if form_error %}
      <p class="alert">{{ t('contact.form_error') }}</p>
      {% endif %}
      <form class="contact-form" method="post" action="{{ path('/contact') }}">
        <input type="hidden" name="csrf" value="{{ csrf_token() }}">
        {% if order_product_id != '' %}
        <input type="hidden" name="product_ref" value="{{ order_product_id }}">
        {% endif %}
        <div class="form-row">
          <label for="name">{{ t('contact.form_name') }}</label>
          <input id="name" name="name" type="text" autocomplete="name" required>
        </div>
        <div class="form-row">
          <label for="email">{{ t('contact.form_email') }}</label>
          <input id="email" name="email" type="email" autocomplete="email">
        </div>
        <div class="form-row">
          <label for="msg">{{ t('contact.form_message') }}</label>
          <textarea id="msg" name="message" required rows="{% if order_message_prefill != '' %}10{% else %}5{% endif %}">{{ order_message_prefill }}</textarea>
        </div>
        <button class="btn btn--primary" type="submit">{{ t('contact.form_submit') }}</button>
      </form>
      <p class="muted contact-hint">{{ t('contact.form_hint') }}</p>
    </div>
  </div>
</section>
{% endblock %}
