{% extends "base.twig" %}

{% block title %}Контакты — {{ site_name }}{% endblock %}

{% block body %}
<section class="page-hero">
  <div class="container">
    <h1>Свяжитесь со мной</h1>
    <p class="muted">Расскажите о вашей идее — вместе создадим украшение из бисера.</p>
  </div>
</section>

<section class="section section--white">
  <div class="container contact-grid">
    <div class="box">
      <h2 style="font-family:var(--display);margin-top:0">Контакты</h2>
      <p><strong>Телефон:</strong> <a href="tel:{{ contact_phone|replace({' ': '', '(': '', ')': '', '-': ''}) }}">{{ contact_phone }}</a></p>
      <p><strong>Email:</strong> <a href="mailto:{{ contact_email }}">{{ contact_email }}</a></p>
      <p class="muted" style="margin-bottom:0">Соцсети: 
        <a href="{{ social_instagram }}">Instagram</a> · 
        <a href="{{ social_telegram }}">Telegram</a> · 
        <a href="{{ social_vk }}">ВКонтакте</a>
      </p>
    </div>
    <div class="box">
      <h2 style="font-family:var(--display);margin-top:0">Написать сообщение</h2>
      <p class="muted" style="margin-top:0">Форма демонстрационная — напишите на email или в мессенджер.</p>
      <form id="contact-form" onsubmit="event.preventDefault();alert('Спасибо! Напишите на email — так сообщение точно дойдёт.');">
        <div class="form-row">
          <label for="name">Имя</label>
          <input id="name" name="name" type="text" autocomplete="name">
        </div>
        <div class="form-row">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email">
        </div>
        <div class="form-row">
          <label for="msg">Сообщение</label>
          <textarea id="msg" name="message"></textarea>
        </div>
        <button class="btn btn--primary" type="submit">Отправить</button>
      </form>
    </div>
  </div>
</section>
{% endblock %}
