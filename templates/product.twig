{% extends "base.twig" %}

{% block title %}{{ product.name }}{% if category_name is defined and category_name %} — {{ category_name }}{% endif %} | купить украшение из бисера | {{ site_name }}{% endblock %}
{% block meta_description %}{{ product.name }}{% if category_name is defined and category_name %} ({{ category_name }}){% endif %} — {% set _desc = product.description|striptags|replace({"\n": ' ', "\r": ' '})|trim %}{{ _desc|slice(0, 120) }}{% if _desc|length > 120 %}…{% endif %} Купить бижутерию ручной работы.{% endblock %}
{% block meta_keywords %}{{ product.name }}, {% if category_name is defined and category_name %}{{ category_name }}, {% endif %}украшение из бисера, бижутерия ручной работы, купить подарок, {{ site_name }}{% endblock %}
{% block og_type %}product{% endblock %}
{% block social_image %}
{% if product.images[0] is defined and product.images[0] %}
<meta property="og:image" content="{{ absolute_url(product.images[0]) }}">
<meta name="twitter:image" content="{{ absolute_url(product.images[0]) }}">
{% else %}
{{ parent() }}
{% endif %}
{% endblock %}
{% block head_structured_extra %}
{% if breadcrumb_json_ld is defined and breadcrumb_json_ld != '' %}
<script type="application/ld+json">{{ breadcrumb_json_ld|raw }}</script>
{% endif %}
{% if product_json_ld is defined and product_json_ld != '' %}
<script type="application/ld+json">{{ product_json_ld|raw }}</script>
{% endif %}
{% endblock %}

{% block body %}
{% if layout_visible('layout.show_product_breadcrumbs') %}
<section class="section section--tight section--white">
  <div class="container">
    <nav class="breadcrumbs" aria-label="Навигация">
      <a href="{{ path('/') }}">{{ t('product.breadcrumb_home') }}</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="{{ path('/catalog') }}">{{ t('product.breadcrumb_catalog') }}</a>
      {% if category_name %}
      <span class="breadcrumbs__sep">/</span>
      <a href="{{ catalog_url(product.category, null, null) }}">{{ category_name }}</a>
      {% endif %}
      <span class="breadcrumbs__sep">/</span>
      <span class="breadcrumbs__current">{{ product.name }}</span>
    </nav>
  </div>
</section>
{% endif %}

{% set _gallery_left = layout_visible('layout.show_product_gallery_main') or (layout_visible('layout.show_product_gallery_thumbs') and product.images|length > 1) %}
{% set _info_keys = ['layout.show_product_title', 'layout.show_product_price', 'layout.show_product_description', 'layout.show_product_meta', 'layout.show_product_materials', 'layout.show_product_order_title', 'layout.show_product_order_steps', 'layout.show_product_btn_order', 'layout.show_product_btn_telegram', 'layout.show_product_btn_whatsapp'] %}
{% if _gallery_left or layout_any_visible(_info_keys) %}
<section class="section section--white">
  <div class="container product-layout">
    {% if _gallery_left %}
    <div>
      {% if layout_visible('layout.show_product_gallery_main') %}
      <div class="gallery-main">
        {% set main = product.images[0] ?? '/images/placeholder.svg' %}
        <img id="main-img" src="{{ main }}" alt="{{ product.name }}" width="600" height="600" class="gallery-main__img">
      </div>
      {% endif %}
      {% if layout_visible('layout.show_product_gallery_thumbs') and product.images|length > 1 %}
      <div class="thumbs" role="tablist">
        {% for img in product.images %}
        <button type="button" data-src="{{ img }}" class="thumb-btn {{ loop.first ? 'is-active' : '' }}" aria-label="Миниатюра {{ loop.index }}">
          <img src="{{ img }}" alt="" width="72" height="72" class="thumb-btn__img">
        </button>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    {% endif %}
    {% if layout_any_visible(_info_keys) %}
    <div class="product-info">
      {% if layout_visible('layout.show_product_title') %}
      <h1 class="product-info__title">{{ product.name }}</h1>
      {% endif %}
      {% if layout_visible('layout.show_product_price') %}
      <p class="product-info__price">{{ product.price|price_rub }}</p>
      {% endif %}
      {% if layout_visible('layout.show_product_description') %}
      <p class="muted product-info__desc">{{ product.description }}</p>
      {% endif %}
      {% if layout_visible('layout.show_product_meta') %}
      <dl class="product-meta">
        <div><dt>{{ t('product.meta_technique') }}</dt><dd>{{ product.technique }}</dd></div>
        {% if product.size %}<div><dt>{{ t('product.meta_size') }}</dt><dd>{{ product.size }}</dd></div>{% endif %}
        <div><dt>{{ t('product.meta_stock') }}</dt><dd>{{ product.in_stock ? t('product.meta_stock_yes') : t('product.meta_stock_no') }}</dd></div>
      </dl>
      {% endif %}
      {% if layout_visible('layout.show_product_materials') and product.materials|length %}
      <p class="product-info__label"><strong>{{ t('product.materials_label') }}</strong></p>
      <ul class="meta-list">
        {% for m in product.materials %}
        <li>{{ m }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      {% if layout_visible('layout.show_product_order_title') or layout_visible('layout.show_product_order_steps') %}
      <div class="order-steps">
        {% if layout_visible('layout.show_product_order_title') %}
        <h2 class="order-steps__title">{{ t('product.order_title') }}</h2>
        {% endif %}
        {% if layout_visible('layout.show_product_order_steps') %}
        <ol class="order-steps__list">
          <li>{{ t('product.order_step_1')|raw }}</li>
          <li>{{ t('product.order_step_2')|raw }}</li>
          <li>{{ t('product.order_step_3')|raw }}</li>
        </ol>
        {% endif %}
      </div>
      {% endif %}

      {% if layout_visible('layout.show_product_btn_order') %}
      <div class="btn-row product-actions">
        <a class="btn btn--primary" href="{{ path('/contact') }}?product={{ product.id|url_encode }}">{{ t('product.btn_order') }}</a>
      </div>
      {% endif %}
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% if reviews|length and layout_any_visible(['layout.show_product_reviews_title', 'layout.show_product_review_items']) %}
<section class="section">
  <div class="container">
    {% if layout_visible('layout.show_product_reviews_title') %}
    <h2 class="section-title">{{ t('product.reviews_title') }}</h2>
    {% endif %}
    {% if layout_visible('layout.show_product_review_items') %}
    {% for r in reviews %}
    <div class="review">
      <div class="review__head">
        <span>{{ r.author }}</span>
        <span class="muted">{{ r.date|slice(0, 10) }}</span>
      </div>
      <p class="stars-rating" aria-label="Оценка {{ r.rating }} из 5">{{ r.rating|stars }}</p>
      <p class="muted review__text">{{ r.text }}</p>
    </div>
    {% endfor %}
    {% endif %}
  </div>
</section>
{% endif %}
{% endblock %}

{% block scripts %}
<script>
(function () {
  var main = document.getElementById('main-img');
  if (!main) return;
  document.querySelectorAll('.thumb-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var src = btn.getAttribute('data-src');
      if (src) main.src = src;
      document.querySelectorAll('.thumb-btn').forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
    });
  });
})();
</script>
{% endblock %}
