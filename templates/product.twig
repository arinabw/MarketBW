{% extends "base.twig" %}

{% block title %}{{ product.name }} — {{ site_name }}{% endblock %}

{% block body %}
<section class="section section--white" style="padding-top:1rem">
  <div class="container">
    <p><a href="/catalog">← Вернуться в каталог</a></p>
  </div>
</section>

<section class="section section--white">
  <div class="container product-layout">
    <div>
      <div class="gallery-main">
        {% set main = product.images[0] ?? '/images/placeholder.svg' %}
        <img id="main-img" src="{{ main }}" alt="{{ product.name }}" width="600" height="600" style="width:100%;height:auto;display:block">
      </div>
      {% if product.images|length > 1 %}
      <div class="thumbs" role="tablist">
        {% for img in product.images %}
        <button type="button" data-src="{{ img }}" class="{{ loop.first ? 'is-active' : '' }}" aria-label="Миниатюра {{ loop.index }}">
          <img src="{{ img }}" alt="" width="72" height="72" style="width:100%;height:100%;object-fit:cover">
        </button>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    <div>
      <h1 style="font-family:var(--display);margin-top:0">{{ product.name }}</h1>
      <p style="font-size:1.35rem;font-weight:700;color:var(--primary-dark)">{{ product.price|price_rub }}</p>
      <p class="muted">{{ product.description }}</p>
      <p><strong>Техника:</strong> {{ product.technique }}</p>
      {% if product.size %}<p><strong>Размер:</strong> {{ product.size }}</p>{% endif %}
      <p><strong>В наличии:</strong> {{ product.in_stock ? 'да' : 'нет' }}</p>
      {% if product.materials|length %}
      <p><strong>Материалы:</strong></p>
      <ul class="meta-list">
        {% for m in product.materials %}
        <li>{{ m }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      <div class="btn-row">
        <a class="btn btn--primary" href="/contact">Заказать / вопрос</a>
      </div>
    </div>
  </div>
</section>

{% if reviews|length %}
<section class="section">
  <div class="container">
    <h2 class="section-title">Отзывы об этом изделии</h2>
    {% for r in reviews %}
    <div class="review">
      <div class="review__head">
        <span>{{ r.author }}</span>
        <span class="muted">{{ r.date|slice(0, 10) }}</span>
      </div>
      <p class="muted" style="margin:0">{{ r.text }}</p>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}
{% endblock %}

{% block scripts %}
<script>
(function () {
  var main = document.getElementById('main-img');
  if (!main) return;
  document.querySelectorAll('.thumbs button').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var src = btn.getAttribute('data-src');
      if (src) main.src = src;
      document.querySelectorAll('.thumbs button').forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
    });
  });
})();
</script>
{% endblock %}
