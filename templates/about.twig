{% extends "base.twig" %}

{% block title %}{{ t('about.page_title') }} — {{ site_name }}{% endblock %}

{% block body %}
<section class="page-hero">
  <div class="container">
    <h1>{{ t('about.page_title') }}</h1>
    <p class="muted">{{ master_tagline }}</p>
  </div>
</section>

<section class="section section--white">
  <div class="container about-page">
    <div class="about-page__intro box">
      <h2 class="about-page__name">{{ master_name }}</h2>
      <p>{{ t('about.intro_p1') }}</p>
      <p>{{ t('about.intro_p2') }}</p>
    </div>
    <div class="about-page__cta">
      <a class="btn btn--primary" href="/catalog">{{ t('about.btn_catalog') }}</a>
      <a class="btn btn--ghost" href="/contact">{{ t('about.btn_contact') }}</a>
    </div>
  </div>
</section>
{% endblock %}
