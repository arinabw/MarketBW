{% extends "base.twig" %}

{% block title %}{% if catalog_category_name is defined and catalog_category_name != '' %}{{ catalog_category_name }} — {% endif %}{{ t('catalog.page_title') }} украшений из бисера | {{ site_name }}{% endblock %}
{% block meta_description %}{% if catalog_category_name is defined and catalog_category_name != '' %}{{ catalog_category_name }} — украшения из бисера ручной работы. {% endif %}{{ t('catalog.page_sub')|slice(0, 140) }}{% endblock %}
{% block meta_keywords %}каталог украшений из бисера, купить бижутерию, бисерные украшения, колье из бисера, браслеты из бисера, серьги из бисера, броши ручной работы, оригинальные подарки, {{ site_name }}{% endblock %}

{% block head_canonical %}
{% if catalog_canonical is defined and catalog_canonical != '' %}
  <link rel="canonical" href="{{ catalog_canonical }}">
  <link rel="alternate" hreflang="ru-RU" href="{{ catalog_canonical }}">
  <link rel="alternate" hreflang="x-default" href="{{ catalog_canonical }}">
{% else %}
  {{ parent() }}
{% endif %}
{% endblock %}
{% block head_structured_extra %}
{% if breadcrumb_json_ld is defined and breadcrumb_json_ld != '' %}
<script type="application/ld+json">{{ breadcrumb_json_ld|raw }}</script>
{% endif %}
{% if itemlist_json_ld is defined and itemlist_json_ld != '' %}
<script type="application/ld+json">{{ itemlist_json_ld|raw }}</script>
{% endif %}
{% endblock %}

{% block body %}
<section class="page-hero">
  <div class="container">
    <h1>{{ t('catalog.page_title') }}</h1>
    <p class="muted">{{ t('catalog.page_sub') }}</p>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    <form class="catalog-toolbar" method="get" action="{{ path('/catalog') }}">
      {% if active_category %}
      <input type="hidden" name="category" value="{{ active_category }}">
      {% endif %}
      <label class="catalog-toolbar__search">
        <span class="visually-hidden">{{ t('catalog.search_placeholder') }}</span>
        <input type="search" name="q" value="{{ search_q }}" placeholder="{{ t('catalog.search_placeholder') }}" autocomplete="off">
      </label>
      <label class="catalog-toolbar__sort">
        <span class="visually-hidden">{{ t('catalog.sort_new') }}</span>
        <select name="sort">
          <option value="date_desc" {{ sort == 'date_desc' ? 'selected' }}>{{ t('catalog.sort_new') }}</option>
          <option value="price_asc" {{ sort == 'price_asc' ? 'selected' }}>{{ t('catalog.sort_price_asc') }}</option>
          <option value="price_desc" {{ sort == 'price_desc' ? 'selected' }}>{{ t('catalog.sort_price_desc') }}</option>
        </select>
      </label>
      <button class="btn btn--primary catalog-toolbar__btn" type="submit">{{ t('catalog.btn_apply') }}</button>
    </form>

    <div class="filters">
      <a class="chip {{ active_category is empty ? 'is-active' : '' }}" href="{{ catalog_url(null, search_q, sort) }}">{{ t('catalog.chip_all') }}</a>
      {% for c in categories %}
      <a class="chip {{ active_category == c.id ? 'is-active' : '' }}" href="{{ catalog_url(c.id, search_q, sort) }}">{{ c.name }}</a>
      {% endfor %}
    </div>

    <div class="grid-cards">
      {% for p in products %}
      <article class="card">
        <a href="{{ path('/product/' ~ p.id) }}" class="card__img">
          {% set img = p.images[0] ?? '/images/placeholder.svg' %}
          <img src="{{ img }}" alt="{{ p.name }} — украшение из бисера ручной работы" loading="lazy" width="400" height="400">
        </a>
        <div class="card__body">
          <h2 class="card__title"><a href="{{ path('/product/' ~ p.id) }}">{{ p.name }}</a></h2>
          <div class="card__meta">{{ p.price|price_rub }}</div>
          <p class="card__text">{{ p.description|slice(0, 110) }}{% if p.description|length > 110 %}…{% endif %}</p>
          <a class="card__link" href="{{ path('/product/' ~ p.id) }}">{{ t('catalog.card_open') }}</a>
        </div>
      </article>
      {% else %}
      <p class="muted empty-hint">{{ t('catalog.empty_hint')|raw }}</p>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}
