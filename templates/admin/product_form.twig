{% extends "admin/layout.twig" %}

{% block title %}{{ product ? 'Редактирование' : 'Новый товар' }}{% endblock %}

{% block content %}
{% set f = form|default({}) %}
<h1 style="font-family:var(--display);margin-top:0">{{ product ? 'Редактировать товар' : 'Новый товар' }}</h1>
{% if error is defined %}
<div class="alert">{{ error }}</div>
{% endif %}
<form method="post" enctype="multipart/form-data" class="box" style="margin-top:1rem">
  <input type="hidden" name="csrf" value="{{ csrf_token() }}">
  <div class="form-row">
    <label for="name">Название *</label>
    <input id="name" name="name" required value="{{ f.name|default(product ? product.name : '') }}">
  </div>
  <div class="form-row">
    <label for="description">Описание</label>
    <textarea id="description" name="description">{{ f.description|default(product ? product.description : '') }}</textarea>
  </div>
  <div class="form-row">
    <label for="price">Цена *</label>
    <input id="price" name="price" type="text" required value="{{ f.price|default(product ? product.price : '') }}">
  </div>
  <div class="form-row">
    <label for="category">Категория (id) *</label>
    <select id="category" name="category" required>
      <option value="">— выберите —</option>
      {% for c in categories %}
      <option value="{{ c.id }}" {% if f.category|default(product ? product.category : '') == c.id %}selected{% endif %}>{{ c.name }} ({{ c.id }})</option>
      {% endfor %}
    </select>
  </div>
  <div class="form-row">
    <label for="image_paths">Пути к изображениям (по одному в строке, только <code>/images/…</code>). Не вставляйте base64 — загрузите файлы полем ниже или укажите готовый путь.</label>
    <textarea id="image_paths" name="image_paths" rows="5" placeholder="/images/products/photo.jpg" spellcheck="false">{{ f.image_paths|default(product ? product.images|join("\n") : '') }}</textarea>
  </div>
  {% if product and product.images|length %}
  <div class="form-row">
    <p class="admin-upload-label">Сейчас в карточке товара</p>
    <div class="admin-upload-preview" aria-hidden="true">
      {% for src in product.images %}
      <figure class="admin-upload-preview__item">
        <img src="{{ src }}" alt="" loading="lazy" width="200" height="140">
        <figcaption class="admin-upload-preview__caption">{{ src }}</figcaption>
      </figure>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  <div class="form-row">
    <label for="images">Загрузить файлы (несколько)</label>
    <input id="images" name="images[]" type="file" accept=".jpg,.jpeg,.png,.gif,.webp,.svg" multiple>
    <div id="product-files-preview" class="admin-upload-preview--pending" hidden>
      <p class="admin-upload-label">Выбрано для загрузки — появится на сайте после «Сохранить»</p>
      <div id="product-files-preview-inner" class="admin-upload-preview"></div>
    </div>
  </div>
  <div class="form-row">
    <label for="materials">Материалы (по строке)</label>
    <textarea id="materials" name="materials" rows="4">{{ f.materials|default(product ? product.materials|join("\n") : '') }}</textarea>
  </div>
  <div class="form-row">
    <label for="size">Размер</label>
    <input id="size" name="size" value="{{ f.size|default(product ? product.size : '') }}">
  </div>
  <div class="form-row">
    <label for="technique">Техника</label>
    <input id="technique" name="technique" value="{{ f.technique|default(product ? product.technique : '') }}">
  </div>
  <div class="form-row" style="display:flex;gap:1rem;flex-wrap:wrap">
    <label><input type="checkbox" name="in_stock" {% if product is null or product.in_stock %}checked{% endif %}> В наличии</label>
    <label><input type="checkbox" name="featured" {% if product and product.featured %}checked{% endif %}> В избранном на главной</label>
  </div>
  <button class="btn btn--primary" type="submit">Сохранить</button>
  <a class="btn btn--ghost" href="{{ path('/admin/products') }}">Отмена</a>
</form>
{% endblock %}
{% block scripts %}
<script>
(function () {
  var input = document.getElementById('images');
  var wrap = document.getElementById('product-files-preview');
  var inner = document.getElementById('product-files-preview-inner');
  if (!input || !wrap || !inner) return;
  var urls = [];
  function revokeAll() {
    urls.forEach(function (u) { try { URL.revokeObjectURL(u); } catch (e) {} });
    urls = [];
  }
  input.addEventListener('change', function () {
    revokeAll();
    inner.innerHTML = '';
    var files = input.files ? Array.prototype.slice.call(input.files) : [];
    if (!files.length) {
      wrap.hidden = true;
      return;
    }
    wrap.hidden = false;
    files.forEach(function (file) {
      var u = URL.createObjectURL(file);
      urls.push(u);
      var fig = document.createElement('figure');
      fig.className = 'admin-upload-preview__item';
      var img = document.createElement('img');
      img.src = u;
      img.alt = file.name;
      fig.appendChild(img);
      var cap = document.createElement('figcaption');
      cap.className = 'admin-upload-preview__caption';
      cap.textContent = file.name + ' (' + (file.size < 1024 ? file.size + ' B' : (file.size < 1048576 ? (file.size / 1024).toFixed(1) + ' KB' : (file.size / 1048576).toFixed(1) + ' MB')) + ')';
      fig.appendChild(cap);
      inner.appendChild(fig);
    });
  });
})();
</script>
{% endblock %}
