{% extends "admin/layout.twig" %}

{% block title %}{{ product ? 'Редактирование' : 'Новый товар' }}{% endblock %}

{% block content %}
<h1 style="font-family:var(--display);margin-top:0">{{ product ? 'Редактировать товар' : 'Новый товар' }}</h1>
{% if error is defined %}
<div class="alert">{{ error }}</div>
{% endif %}
<form method="post" enctype="multipart/form-data" class="box" style="margin-top:1rem">
  <input type="hidden" name="csrf" value="{{ csrf_token() }}">
  <div class="form-row">
    <label for="name">Название *</label>
    <input id="name" name="name" required value="{{ product ? product.name : (form.name ?? '') }}">
  </div>
  <div class="form-row">
    <label for="description">Описание</label>
    <textarea id="description" name="description">{{ product ? product.description : (form.description ?? '') }}</textarea>
  </div>
  <div class="form-row">
    <label for="price">Цена *</label>
    <input id="price" name="price" type="text" required value="{{ product ? product.price : (form.price ?? '') }}">
  </div>
  <div class="form-row">
    <label for="category">Категория (id) *</label>
    <select id="category" name="category" required>
      <option value="">— выберите —</option>
      {% for c in categories %}
      <option value="{{ c.id }}" {% if product and product.category == c.id %}selected{% elseif form.category|default('') == c.id %}selected{% endif %}>{{ c.name }} ({{ c.id }})</option>
      {% endfor %}
    </select>
  </div>
  <div class="form-row">
    <label for="image_paths">Пути к изображениям (по одному в строке, URL с /images/...)</label>
    <textarea id="image_paths" name="image_paths" rows="4" placeholder="/images/products/1.svg">{% if product %}{{ product.images|join("\n") }}{% else %}{{ form.image_paths ?? '' }}{% endif %}</textarea>
  </div>
  <div class="form-row">
    <label for="images">Загрузить файлы (несколько)</label>
    <input id="images" name="images[]" type="file" accept=".jpg,.jpeg,.png,.gif,.webp,.svg" multiple>
  </div>
  <div class="form-row">
    <label for="materials">Материалы (по строке)</label>
    <textarea id="materials" name="materials" rows="4">{% if product %}{{ product.materials|join("\n") }}{% else %}{{ form.materials ?? '' }}{% endif %}</textarea>
  </div>
  <div class="form-row">
    <label for="size">Размер</label>
    <input id="size" name="size" value="{{ product ? product.size : (form.size ?? '') }}">
  </div>
  <div class="form-row">
    <label for="technique">Техника</label>
    <input id="technique" name="technique" value="{{ product ? product.technique : (form.technique ?? '') }}">
  </div>
  <div class="form-row" style="display:flex;gap:1rem;flex-wrap:wrap">
    <label><input type="checkbox" name="in_stock" {% if product is null or product.in_stock %}checked{% endif %}> В наличии</label>
    <label><input type="checkbox" name="featured" {% if product and product.featured %}checked{% endif %}> В избранном на главной</label>
  </div>
  <button class="btn btn--primary" type="submit">Сохранить</button>
  <a class="btn btn--ghost" href="/admin/products">Отмена</a>
</form>
{% endblock %}
