{% extends "admin/layout.twig" %}

{% block title %}Статья{% endblock %}

{% block content %}
{% set f = form|default({}) %}
{% set a = article %}
<h1 style="font-family:var(--display);margin-top:0">{{ a ? 'Редактировать статью' : 'Новая статья' }}</h1>
{% if error is defined %}
<div class="alert">{{ error }}</div>
{% endif %}
<form method="post" class="box" style="margin-top:1rem">
  <input type="hidden" name="csrf" value="{{ csrf_token() }}">
  <div class="form-row">
    <label for="topic_id">Тема *</label>
    <select id="topic_id" name="topic_id" required>
      {% for t in topics %}
      <option value="{{ t.id }}" {{ (f.topic_id|default(a ? a.topic_id : '')) == t.id ? 'selected' : '' }}>{{ t.name }}</option>
      {% endfor %}
    </select>
  </div>
  <div class="form-row">
    <label for="title">Заголовок *</label>
    <input id="title" name="title" required value="{{ f.title|default(a ? a.title : '') }}">
  </div>
  <div class="form-row">
    <label for="slug">Адрес в URL (slug, латиница)</label>
    <input id="slug" name="slug" value="{{ f.slug|default(a ? a.slug : '') }}" placeholder="например: kak-vybrat-biser">
    <span class="muted" style="font-size:0.85rem">Если пусто — сгенерируется из заголовка.</span>
  </div>
  <div class="form-row">
    <label for="excerpt">Краткое описание (анонс)</label>
    <textarea id="excerpt" name="excerpt" rows="2">{{ f.excerpt|default(a ? a.excerpt : '') }}</textarea>
  </div>
  <div class="form-row">
    <label for="body_html">Текст статьи (HTML)</label>
    <textarea id="body_html" name="body_html" rows="16" class="mono">{{ f.body_html|default(a ? a.body_html : '') }}</textarea>
  </div>
  <div class="form-row">
    <label for="sort_order">Порядок сортировки</label>
    <input id="sort_order" name="sort_order" type="number" value="{{ f.sort_order|default(a ? a.sort_order : 0) }}">
  </div>
  <div class="form-row">
    <label>
      <input type="checkbox" name="published" value="1" {% if f.published is defined and f.published %}checked{% elseif a and a.published %}checked{% endif %}>
      Опубликовать на сайте
    </label>
  </div>
  <button class="btn btn--primary" type="submit">Сохранить</button>
  <a class="btn btn--ghost" href="{{ path('/admin/articles') }}">Отмена</a>
</form>
{% endblock %}
