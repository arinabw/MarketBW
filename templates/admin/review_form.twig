{% extends "admin/layout.twig" %}

{% block title %}Отзыв{% endblock %}

{% block content %}
{% set f = form|default({}) %}
<h1 style="font-family:var(--display);margin-top:0">{{ review ? 'Редактировать отзыв' : 'Новый отзыв' }}</h1>
{% if error is defined %}
<div class="alert">{{ error }}</div>
{% endif %}
<form method="post" class="box" style="margin-top:1rem">
  <input type="hidden" name="csrf" value="{{ csrf_token() }}">
  <div class="form-row">
    <label for="author">Автор *</label>
    <input id="author" name="author" required value="{{ f.author|default(review ? review.author : '') }}">
  </div>
  <div class="form-row">
    <label for="rating">Оценка (1–5)</label>
    <input id="rating" name="rating" type="number" min="1" max="5" value="{{ f.rating|default(review ? review.rating : 5) }}">
  </div>
  <div class="form-row">
    <label for="text">Текст *</label>
    <textarea id="text" name="text" rows="5" required>{{ f.text|default(review ? review.text : '') }}</textarea>
  </div>
  <div class="form-row">
    <label for="date">Дата</label>
    <input id="date" name="date" value="{{ f.date|default(review ? review.date : '') }}" placeholder="2024-01-15 12:00:00">
  </div>
  <div class="form-row">
    <label for="product_id">Привязка к товару (id, пусто = только на главной)</label>
    <select id="product_id" name="product_id">
      <option value="">— не привязан —</option>
      {% for p in products %}
      <option value="{{ p.id }}" {% if (f.product_id|default(review ? review.product_id|default('') : '')) == p.id %}selected{% endif %}>{{ p.name }} ({{ p.id }})</option>
      {% endfor %}
    </select>
  </div>
  <button class="btn btn--primary" type="submit">Сохранить</button>
  <a class="btn btn--ghost" href="/admin/reviews">Отмена</a>
</form>
{% endblock %}
