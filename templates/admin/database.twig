{% extends "admin/layout.twig" %}

{% block title %}База данных{% endblock %}

{% block content %}
<h1 class="admin-page-title" style="font-family:var(--display)">База данных</h1>
<p class="muted" style="max-width:48rem;margin-bottom:1rem">
  Таблицы SQLite <code>marketbw.db</code>. Ниже — число строк и превью (до 20). Выгрузка: один файл Excel с листом на каждую таблицу (формат XML Spreadsheet 2003, открывается в Microsoft Excel и LibreOffice).
  Колонка <code>password_hash</code> в <code>users</code> в файле заменена на заглушку — реальные хэши не попадают в выгрузку.
</p>

<form method="post" action="{{ path('/admin/database/export') }}" class="box" style="margin-bottom:1.25rem;display:flex;flex-wrap:wrap;gap:0.75rem;align-items:center">
  <input type="hidden" name="csrf" value="{{ csrf_token() }}">
  <button type="submit" class="btn btn--primary">Выгрузить все данные в Excel</button>
  <span class="muted" style="font-size:0.9rem">Файл: <code>marketbw-db-… .xls</code></span>
</form>

{% for t in db_tables %}
<div class="box" style="margin-bottom:1rem">
  <h2 style="margin:0 0 0.5rem;font-size:1.1rem;font-family:var(--display)">
    <code>{{ t.name }}</code>
    <span class="muted" style="font-weight:400;font-size:0.95rem"> — {{ t.count }} строк</span>
  </h2>
  {% if t.count == 0 and t.preview_rows is empty %}
  <p class="muted" style="margin:0">Таблица пустая{% if t.preview_columns is not empty %} (колонки: {{ t.preview_columns|join(', ') }}){% endif %}.</p>
  {% elseif t.preview_columns is empty %}
  <p class="muted" style="margin:0">Не удалось прочитать структуру таблицы.</p>
  {% else %}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          {% for col in t.preview_columns %}
          <th>{{ col }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in t.preview_rows %}
        <tr>
          {% for col in t.preview_columns %}
          <td style="max-width:14rem;word-break:break-word;font-size:0.88rem">{{ row[col]|default('') }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</div>
{% else %}
<p class="muted">Таблиц не найдено.</p>
{% endfor %}
{% endblock %}
