{% extends "admin/layout.twig" %}

{% block title %}Отзывы{% endblock %}

{% block content %}
<h1 style="font-family:var(--display);margin-top:0">Отзывы</h1>
<p><a class="btn btn--primary" href="/admin/reviews/new">Добавить отзыв</a></p>
<div class="table-wrap" style="margin-top:1rem">
  <table>
    <thead>
      <tr>
        <th>Автор</th>
        <th>Оценка</th>
        <th>Товар</th>
        <th>Дата</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% for r in reviews %}
      <tr>
        <td>{{ r.author }}</td>
        <td>{{ r.rating }}</td>
        <td>{% if r.product_id %}<code>{{ r.product_id }}</code>{% else %}<span class="muted">общий</span>{% endif %}</td>
        <td style="font-size:0.85rem">{{ r.date|slice(0, 10) }}</td>
        <td style="white-space:nowrap">
          <a href="/admin/reviews/{{ r.id }}/edit">Изменить</a>
          <form class="inline-form" method="post" action="/admin/reviews/{{ r.id }}/delete" style="margin-left:0.5rem" onsubmit="return confirm('Удалить отзыв?');">
            <input type="hidden" name="csrf" value="{{ csrf_token() }}">
            <button type="submit" class="btn btn--ghost" style="padding:0.25rem 0.5rem;font-size:0.85rem">Удалить</button>
          </form>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="5" class="muted">Нет отзывов.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
