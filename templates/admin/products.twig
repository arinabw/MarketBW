{% extends "admin/layout.twig" %}

{% block title %}Товары{% endblock %}

{% block content %}
<h1 style="font-family:var(--display);margin-top:0">Товары</h1>
<p><a class="btn btn--primary" href="/admin/products/new">Добавить товар</a></p>
<div class="table-wrap" style="margin-top:1rem">
  <table>
    <thead>
      <tr>
        <th class="admin-col-thumb" aria-label="Фото"></th>
        <th>Название</th>
        <th>Цена</th>
        <th>Категория</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% for p in products %}
      <tr>
        <td class="admin-col-thumb">
          {% if p.images|length %}
          <a href="/product/{{ p.id }}" target="_blank" rel="noopener" title="Открыть на сайте"><img class="admin-table-thumb" src="{{ p.images[0] }}" alt="" loading="lazy" width="56" height="56"></a>
          {% else %}
          <span class="muted" title="Нет фото">—</span>
          {% endif %}
        </td>
        <td><a href="/product/{{ p.id }}" target="_blank" rel="noopener">{{ p.name }}</a></td>
        <td>{{ p.price|price_rub }}</td>
        <td>{{ p.category }}</td>
        <td style="white-space:nowrap">
          <a href="/admin/products/{{ p.id }}/edit">Изменить</a>
          <form class="inline-form" method="post" action="/admin/products/{{ p.id }}/delete" style="margin-left:0.5rem" onsubmit="return confirm('Удалить товар?');">
            <input type="hidden" name="csrf" value="{{ csrf_token() }}">
            <button type="submit" class="btn btn--ghost" style="padding:0.25rem 0.5rem;font-size:0.85rem">Удалить</button>
          </form>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="5" class="muted">Нет товаров — <a href="/admin/products/new">создать</a>.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
