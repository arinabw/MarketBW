{% extends "admin/layout.twig" %}

{% block title %}Смена пароля{% endblock %}

{% block content %}
<h1 class="admin-page-title">Смена пароля</h1>
{% if error is defined %}
<div class="alert">{{ error }}</div>
{% endif %}
{% if success is defined %}
<div class="alert alert--success">{{ success }}</div>
{% endif %}
<form method="post" action="{{ path('/admin/password') }}" class="box" style="max-width:420px">
  <input type="hidden" name="csrf" value="{{ csrf_token() }}">
  <div class="form-row">
    <label for="old_password">Текущий пароль</label>
    <input id="old_password" name="old_password" type="password" required autocomplete="current-password">
  </div>
  <div class="form-row">
    <label for="new_password">Новый пароль (не менее 8 символов)</label>
    <input id="new_password" name="new_password" type="password" required autocomplete="new-password" minlength="8">
  </div>
  <div class="form-row">
    <label for="new_password_confirm">Повтор нового пароля</label>
    <input id="new_password_confirm" name="new_password_confirm" type="password" required autocomplete="new-password" minlength="8">
  </div>
  <button class="btn btn--primary" type="submit">Сохранить</button>
</form>
{% endblock %}
