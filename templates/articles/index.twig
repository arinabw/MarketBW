{% extends "base.twig" %}

{% block title %}{{ t('articles.page_title') }} — бисероплетение, техники и идеи | {{ site_name }}{% endblock %}
{% block meta_description %}Статьи о бисере и бисероплетении: материалы, техники плетения, идеи украшений, история рукоделия. {{ site_name }}.{% endblock %}

{% block head_structured_extra %}
{% if breadcrumb_json_ld is defined and breadcrumb_json_ld != '' %}
<script type="application/ld+json">{{ breadcrumb_json_ld|raw }}</script>
{% endif %}
{% if collection_json_ld is defined and collection_json_ld != '' %}
<script type="application/ld+json">{{ collection_json_ld|raw }}</script>
{% endif %}
{% endblock %}

{% block body %}
<section class="page-hero">
  <div class="container">
    <h1>{{ t('articles.page_title') }}</h1>
    <p class="muted">{{ t('articles.page_sub') }}</p>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    {% if topics|length > 0 %}
    <div class="topic-grid">
      {% for topic in topics %}
      <a class="topic-card" href="{{ path('/articles/' ~ topic.slug) }}">
        {% if topic.icon %}
        <span class="topic-card__icon" aria-hidden="true">{{ topic.icon }}</span>
        {% endif %}
        <span class="topic-card__name">{{ topic.name }}</span>
        {% if topic.description %}
        <span class="topic-card__desc">{{ topic.description }}</span>
        {% endif %}
        <span class="topic-card__footer">
          <span class="topic-card__count">{{ topic.article_count }}
            {%- if topic.article_count == 1 %} статья
            {%- elseif topic.article_count >= 2 and topic.article_count <= 4 %} статьи
            {%- else %} статей{% endif -%}
          </span>
          <span class="topic-card__arrow">&rarr;</span>
        </span>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p class="muted">{{ t('articles.topic_empty') }}</p>
    {% endif %}
  </div>
</section>
{% endblock %}
