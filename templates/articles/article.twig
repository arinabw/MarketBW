{% extends "base.twig" %}

{% block title %}{{ article.title }} — бисероплетение | {{ site_name }}{% endblock %}
{% block meta_description %}{{ article_meta_description|default('') }} {{ site_name }} — статьи о бисере и рукоделии.{% endblock %}
{% block meta_keywords %}{{ article.title }}, {{ article.topic_name }}, бисероплетение, бисер, рукоделие, украшения из бисера, {{ site_name }}{% endblock %}
{% block og_type %}article{% endblock %}

{% block head_structured_extra %}
{% if breadcrumb_json_ld is defined and breadcrumb_json_ld != '' %}
<script type="application/ld+json">{{ breadcrumb_json_ld|raw }}</script>
{% endif %}
{% if article_json_ld is defined and article_json_ld != '' %}
<script type="application/ld+json">{{ article_json_ld|raw }}</script>
{% endif %}
{% endblock %}

{% block body %}
<article class="article-page">
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Навигация">
        <a href="{{ path('/') }}">Главная</a>
        <span class="breadcrumb__sep">&rsaquo;</span>
        <a href="{{ path('/articles') }}">{{ t('articles.breadcrumb') }}</a>
        <span class="breadcrumb__sep">&rsaquo;</span>
        <a href="{{ path('/articles/' ~ article.topic_slug) }}">{{ article.topic_name }}</a>
      </nav>
      <span class="article-page__kicker">{{ article.topic_name }}</span>
      <h1>{{ article.title }}</h1>
      {% if article.excerpt %}
      <p class="article-page__lead">{{ article.excerpt }}</p>
      {% endif %}
    </div>
  </section>

  <section class="section section--white">
    <div class="container article-body">
      {{ article.body_html|raw }}
    </div>
  </section>

  <section class="article-nav">
    <div class="container">
      <a class="article-nav__back" href="{{ path('/articles/' ~ article.topic_slug) }}">&larr; {{ article.topic_name }}</a>
    </div>
  </section>
</article>
{% endblock %}
