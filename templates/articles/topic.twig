{% extends "base.twig" %}

{% block title %}{{ topic.name }} — статьи о бисере и бисероплетении | {{ site_name }}{% endblock %}
{% block meta_description %}{{ topic.description|default('') }} Статьи и советы по бисероплетению и рукоделию. {{ site_name }}.{% endblock %}

{% block head_structured_extra %}
{% if breadcrumb_json_ld is defined and breadcrumb_json_ld != '' %}
<script type="application/ld+json">{{ breadcrumb_json_ld|raw }}</script>
{% endif %}
{% endblock %}

{% block body %}
<section class="page-hero">
  <div class="container">
    <nav class="breadcrumb" aria-label="Навигация">
      <a href="{{ path('/') }}">Главная</a>
      <span class="breadcrumb__sep">&rsaquo;</span>
      <a href="{{ path('/articles') }}">{{ t('articles.breadcrumb') }}</a>
      <span class="breadcrumb__sep">&rsaquo;</span>
      <span aria-current="page">{{ topic.name }}</span>
    </nav>
    <div class="topic-hero">
      {% if topic.icon %}
      <span class="topic-hero__icon" aria-hidden="true">{{ topic.icon }}</span>
      {% endif %}
      <div>
        <h1>{{ topic.name }}</h1>
        {% if topic.description %}
        <p class="muted">{{ topic.description }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    {% if articles|length > 0 %}
    <div class="article-card-list">
      {% for a in articles %}
      <a class="article-card" href="{{ path('/articles/' ~ a.topic_slug ~ '/' ~ a.slug) }}">
        <span class="article-card__num" aria-hidden="true">{{ "%02d"|format(loop.index) }}</span>
        <span class="article-card__body">
          <span class="article-card__title">{{ a.title }}</span>
          {% if a.excerpt %}
          <span class="article-card__excerpt">{{ a.excerpt }}</span>
          {% endif %}
        </span>
        <span class="article-card__arrow" aria-hidden="true">&rarr;</span>
      </a>
      {% endfor %}
    </div>

    <div class="topic-back">
      <a href="{{ path('/articles') }}">&larr; Все темы</a>
    </div>
    {% else %}
    <p class="muted">{{ t('articles.topic_empty') }}</p>
    <p><a href="{{ path('/articles') }}">&larr; Все темы</a></p>
    {% endif %}
  </div>
</section>
{% endblock %}
