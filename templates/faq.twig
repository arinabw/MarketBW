{% extends "base.twig" %}

{% block title %}{{ t('faq.page_title') }} — {{ site_name }}{% endblock %}

{% block body %}
<section class="page-hero">
  <div class="container">
    <h1>{{ t('faq.page_title') }}</h1>
    <p class="muted">{{ t('faq.page_sub') }}</p>
  </div>
</section>

<section class="section section--white">
  <div class="container" style="max-width:720px;margin:0 auto">
    {% for f in faqs %}
    <div class="faq-item">
      <p class="faq-q">{{ f.question }}</p>
      <p class="faq-a">{{ f.answer }}</p>
    </div>
    {% endfor %}
  </div>
</section>
{% endblock %}
