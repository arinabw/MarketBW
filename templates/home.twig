{% extends "base.twig" %}

{% block meta_description %}{{ t('home.hero_lead')|slice(0, 120) }} — {{ site_name }}. {{ master_tagline|slice(0, 80) }}{% endblock %}

{% block body %}
<section class="hero">
  <div class="container hero__grid">
    <div>
      <div class="badge">{{ t('home.badge_prefix') }}{{ site_name }}{{ t('home.badge_suffix') }}</div>
      <h1>{{ t('home.hero_title') }}<span class="hero__accent">{{ t('home.hero_title_accent') }}</span></h1>
      <p class="lead">{{ t('home.hero_lead') }}</p>
      <div class="btn-row">
        <a class="btn btn--primary" href="/catalog">{{ t('home.btn_catalog') }}</a>
        <a class="btn btn--ghost" href="/contact">{{ t('home.btn_contact') }}</a>
      </div>
    </div>
    <div class="hero-art">
      <div class="hero-art__frame">
        <img src="{{ t('home.hero_image') }}" alt="{{ t('home.hero_image_alt') }}" width="320" height="240" loading="eager">
      </div>
    </div>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    <h2 class="section-title">{{ t('home.section_categories_title') }}</h2>
    <p class="section-sub">{{ t('home.section_categories_sub') }}</p>
    <div class="grid-cards">
      {% for c in categories %}
      <a class="card card--link" href="{{ catalog_url(c.id, null, null) }}">
        <div class="card__img">
          <img src="{{ c.image }}" alt="{{ c.name }}" loading="lazy" width="400" height="400">
        </div>
        <div class="card__body">
          <h3 class="card__title">{{ c.name }}</h3>
          <p class="card__text">{{ c.description }}</p>
          <span class="card__link">{{ t('home.card_link') }}</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section-title">{{ t('home.section_featured_title') }}</h2>
    <p class="section-sub">{{ t('home.section_featured_sub') }}</p>
    <div class="grid-cards">
      {% for p in featured %}
      <article class="card">
        <a href="/product/{{ p.id }}" class="card__img">
          {% set img = p.images[0] ?? '/images/placeholder.svg' %}
          <img src="{{ img }}" alt="{{ p.name }}" loading="lazy" width="400" height="400">
        </a>
        <div class="card__body">
          <h3 class="card__title"><a href="/product/{{ p.id }}">{{ p.name }}</a></h3>
          <div class="card__meta">{{ p.price|price_rub }}</div>
          <p class="card__text">{{ p.description|slice(0, 120) }}{% if p.description|length > 120 %}…{% endif %}</p>
          <a class="card__link" href="/product/{{ p.id }}">{{ t('home.card_more') }}</a>
        </div>
      </article>
      {% else %}
      <p class="muted empty-hint">{{ t('home.featured_empty')|raw }}</p>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    <h2 class="section-title">{{ t('home.section_reviews_title') }}</h2>
    <p class="section-sub">{{ t('home.section_reviews_sub') }}</p>
    <div class="grid-cards reviews-grid">
      {% for r in reviews %}
      <div class="review">
        <div class="review__head">
          <span>{{ r.author }}</span>
          <span class="muted">{{ r.date|slice(0, 10) }}</span>
        </div>
        <p class="stars-rating" aria-label="Оценка {{ r.rating }} из 5">{{ r.rating|stars }}</p>
        <p class="muted review__text">{{ r.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}
