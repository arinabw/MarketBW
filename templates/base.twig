<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  {% block head_robots %}
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1">
  {% endblock %}
  {% set _meta_desc %}{% block meta_description %}{{ t('meta.description') }}{% endblock %}{% endset %}
  {% set _meta_desc_display = _meta_desc|trim|slice(0, 160) %}
  <meta name="description" content="{{ _meta_desc_display|e('html_attr') }}">
  {% set _kw %}{% block meta_keywords %}{{ t('meta.keywords') }}{% endblock %}{% endset %}
  {% if _kw|trim != '' %}
  <meta name="keywords" content="{{ _kw|trim }}">
  {% endif %}
  <title>{% block title %}{{ site_name }}{% endblock %}</title>
  {% block head_canonical %}
  {% if seo_canonical_url != '' %}
  <link rel="canonical" href="{{ seo_canonical_url }}">
  <link rel="alternate" hreflang="ru-RU" href="{{ seo_canonical_url }}">
  <link rel="alternate" hreflang="x-default" href="{{ seo_canonical_url }}">
  {% endif %}
  {% endblock %}
  <meta name="theme-color" content="#fffafb">
  <meta property="og:type" content="{% block og_type %}website{% endblock %}">
  <meta property="og:site_name" content="{{ site_name }}">
  <meta property="og:locale" content="ru_RU">
  {% if seo_canonical_url != '' %}
  <meta property="og:url" content="{{ seo_canonical_url }}">
  {% endif %}
  <meta property="og:title" content="{{ block('title')|trim }}">
  <meta property="og:description" content="{{ _meta_desc_display|e('html_attr') }}">
  {% block social_image %}
  {% if seo_default_og_image != '' %}
  <meta property="og:image" content="{{ seo_default_og_image }}">
  <meta name="twitter:image" content="{{ seo_default_og_image }}">
  {% endif %}
  {% endblock %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ block('title')|trim }}">
  <meta name="twitter:description" content="{{ _meta_desc_display|e('html_attr') }}">
  {% block head_extra %}{% endblock %}
  <link rel="icon" href="{{ path('/favicon.svg') }}" type="image/svg+xml">
  <link rel="apple-touch-icon" href="{{ path('/favicon.svg') }}">
  <link rel="manifest" href="{{ path('/site.webmanifest') }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ path('/css/app.css') }}?v={{ app_version }}">
  {% if seo_website_json_ld != '' %}
  <script type="application/ld+json">{{ seo_website_json_ld|raw }}</script>
  {% endif %}
  {% if seo_organization_json_ld != '' %}
  <script type="application/ld+json">{{ seo_organization_json_ld|raw }}</script>
  {% endif %}
  {% block head_structured_extra %}{% endblock %}
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="site-header__inner">
        <a class="logo" href="{{ path('/') }}">{{ site_name }} <span>·</span> {{ t('header.logo_suffix') }}</a>
        {% include 'partials/main-nav.twig' with { nav_class: 'nav nav--desktop' } %}
        <details class="header-drawer">
          <summary class="header-drawer__toggle">
            <span class="header-drawer__icon" aria-hidden="true"></span>
            <span class="header-drawer__text">Меню</span>
          </summary>
          <div class="header-drawer__panel">
            {% include 'partials/main-nav.twig' with { nav_class: 'nav nav--drawer' } %}
          </div>
        </details>
        <div class="site-header__social">
          <a href="mailto:{{ contact_email }}" title="Email">✉</a>
        </div>
      </div>
    </div>
  </header>
  <main>
    {% block body %}{% endblock %}
  </main>
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-grid">
        <div>© {{ "now"|date("Y") }} {{ site_name }}. {{ master_tagline }}</div>
        <div class="footer-contacts">
          <a href="mailto:{{ contact_email }}">{{ contact_email }}</a>
        </div>
      </div>
      <nav class="footer-nav" aria-label="Дополнительно">
        <a href="{{ path('/about') }}">{{ t('nav.about') }}</a>
        <a href="{{ path('/articles') }}">{{ t('nav.articles') }}</a>
        <a href="{{ path('/faq') }}">{{ t('nav.faq') }}</a>
        <a href="{{ path('/contact') }}">{{ t('nav.contact') }}</a>
        <a href="{{ path('/catalog') }}">{{ t('nav.catalog') }}</a>
      </nav>
      <p class="footer-note">{{ t('footer.note') }}</p>
      <p class="footer-version muted" aria-hidden="true">Версия {{ app_version }}</p>
    </div>
  </footer>
  {% include 'partials/metrika.twig' %}
  {% block scripts %}{% endblock %}
</body>
</html>
