{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "checkJs": false,
    "types": ["vite/client"]
  },
  "include": ["src/**/*.js", "src/**/*.vue", "frontend/vite.config.js"]
}
