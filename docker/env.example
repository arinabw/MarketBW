# === MarketBW (Slim + Twig + SQLite) + Traefik ===
# Скопировать: cp env.example .env

MARKETBW_IMAGE_NAME=marketbw-local
COMPOSE_PROJECT_NAME=marketbw

TRAEFIK_NETWORK=web
SITE_CONTAINER_NAME=marketbw-app
TRAEFIK_ROUTER=marketbw

# Host(`marketbw.ru`) || Host(`www.marketbw.ru`)
TRAEFIK_RULE=Host(`example.com`)

TRAEFIK_HTTPS_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=le

# Контейнер слушает порт 80 (Nginx → PHP-FPM)
# traefik.http.services.<router>.loadbalancer.server.port=80

# Опционально: отладка Twig/ошибок PHP (не в проде)
APP_DEBUG=false

# Если приложение в подкаталоге (не в корне домена), без слэшей: BASE_PATH=shop
# BASE_PATH=

# Опционально: общий cookie-сессии для www и apex (иначе вход «слетает» между хостами)
# SESSION_COOKIE_DOMAIN=.example.com

# Traefik / HTTPS снаружи: true (по умолчанию в compose) — cookie сессии с флагом Secure
# Локально по HTTP к контейнеру: SESSION_FORCE_SECURE=false
# SESSION_FORCE_SECURE=true

# Публичный URL без слэша в конце (переопределяет дефолт https://marketbw.ru из config/settings.php)
# PUBLIC_SITE_URL=https://marketbw.ru

SITE_NAME=Bead Wonder
MASTER_NAME=Мастер
MASTER_TAGLINE=Украшения из бисера ручной работы
CONTACT_EMAIL=your-email@example.com
CONTACT_PHONE=+7 (999) 123-45-67
# Только цифры, например 79991234567 — для кнопки WhatsApp
CONTACT_WHATSAPP=
SOCIAL_INSTAGRAM=#
SOCIAL_TELEGRAM=#
SOCIAL_VK=#
