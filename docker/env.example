# === MarketBW (Slim + Twig + SQLite) + Traefik ===
# Скопировать: cp env.example .env

MARKETBW_IMAGE_NAME=marketbw-local
COMPOSE_PROJECT_NAME=marketbw

TRAEFIK_NETWORK=web
SITE_CONTAINER_NAME=marketbw-app
TRAEFIK_ROUTER=marketbw

# Host(`marketbw.ru`) || Host(`www.marketbw.ru`)
TRAEFIK_RULE=Host(`example.com`)

TRAEFIK_HTTPS_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=le

# Контейнер слушает порт 80 (Nginx → PHP-FPM)
# traefik.http.services.<router>.loadbalancer.server.port=80

# Опционально: отладка Twig/ошибок PHP (не в проде)
APP_DEBUG=false

SITE_NAME=Bead Wonder
CONTACT_EMAIL=your-email@example.com
CONTACT_PHONE=+7 (999) 123-45-67
SOCIAL_INSTAGRAM=#
SOCIAL_TELEGRAM=#
SOCIAL_VK=#
