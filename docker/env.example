# === MarketBW + Traefik (см. https://github.com/idpro1313/webserver) ===
# Скопировать: cp env.example .env
#
# Репозиторий целиком на сервере, например: /opt/MarketBW
# compose и скрипты — из каталога docker/; том БД: ../data → <корень-репо>/data

# Имя образа после сборки (как NODE_IMAGE_NAME в шаблоне node-site)
MARKETBW_IMAGE_NAME=marketbw-local

# Проект Compose (имя для docker compose -p; уникально на сервере)
COMPOSE_PROJECT_NAME=marketbw

# Сеть Traefik (у idpro1313/webserver по умолчанию web)
TRAEFIK_NETWORK=web

# Уникальное имя контейнера (не пересекаться с другими сайтами)
SITE_CONTAINER_NAME=marketbw-app

# Уникальное имя роутера Traefik (латиница, без пробелов)
TRAEFIK_ROUTER=marketbw

# Правило Host — обратные кавычки вокруг доменов обязательны:
# TRAEFIK_RULE=Host(`example.com`) || Host(`www.example.com`)
TRAEFIK_RULE=Host(`example.com`)

# Имена из reverse-proxy Traefik (если отличаются — поправьте)
TRAEFIK_HTTPS_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=le
