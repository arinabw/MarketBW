    <M-TWIG-ARTICLES NAME="ArticleTemplates" TYPE="UI_COMPONENT" STATUS="implemented">
      <purpose>Шаблоны статей: index (темы), topic (список), article (полный текст)</purpose>
      <path>templates/articles/index.twig, templates/articles/topic.twig, templates/articles/article.twig</path>
      <depends>M-TWIG-BASE, M-ARTICLE-CONTENT</depends>
      <annotations>
        <export-index PURPOSE="Сетка тем (topic-grid, topic-card с иконками и счётчиками); CollectionPage JSON-LD" />
        <export-topic PURPOSE="Карточки статей (article-card-list) с номерами; topic-hero с иконкой; breadcrumbs" />
        <export-article PURPOSE="Полный текст с article-table, article-body; BlogPosting JSON-LD; article-nav" />
