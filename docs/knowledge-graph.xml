      <purpose>Базовый HTML: head (SEO, OG, JSON-LD), header, nav, footer</purpose>
      <path>templates/base.twig</path>
      <depends>M-CONTENT-DEFAULTS, M-SEO</depends>
      <annotations>
        <export-head PURPOSE="Блоки title, meta (keywords, description), OG, canonical, JSON-LD; CSS cache-busting ?v=app_version" />
